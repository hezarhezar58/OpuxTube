<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- AppCompat parent so AppCompatActivity boots without crashing; the visual surface
         is provided by our Compose `OpuxTubeTheme` so the parent only needs to be
         AppCompat-compatible. NoActionBar variant keeps the Compose top app bar in charge. -->
    <style name="Theme.OpuxTube" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Cold-start splash. Shown while OpuxApplication.onCreate / Hilt graph build /
         Compose first frame run. installSplashScreen() in MainActivity transitions to
         Theme.OpuxTube as the post-splash surface. -->
    <style name="Theme.OpuxTube.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/ic_launcher_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.OpuxTube</item>
    </style>
</resources>
